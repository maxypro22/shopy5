{%- assign is_ar = false -%}
{%- if request.locale.iso_code contains 'ar' -%}{%- assign is_ar = true -%}{%- endif -%}

{%- assign blog_handle = section.settings.blog -%}
{%- assign news_blog = blogs[blog_handle] -%}
{%- assign posts_count = section.settings.posts_count | default: 4 -%}

<section class="sf-news" id="sf-news-{{ section.id }}">
  <div class="container">
    <div class="sf-news__head">
      <h2 class="sf-news__title">
        {%- if section.settings.title != blank -%}{{ section.settings.title }}{%- elsif is_ar -%}آخر الأخبار{%- else -%}Recent News{%- endif -%}
      </h2>
      {%- if news_blog != blank -%}
        <a href="{{ news_blog.url }}" class="sf-news__see-more">
          {%- if is_ar -%}عرض المزيد{%- else -%}See More{%- endif -%}
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M5 12h14M12 5l7 7-7 7"/></svg>
        </a>
      {%- endif -%}
    </div>

    {%- if news_blog != blank and news_blog.articles.size > 0 -%}
      <div class="sf-news__grid">
        {%- for article in news_blog.articles limit: posts_count -%}
          <article class="sf-news__card" style="--ni: {{ forloop.index0 }};">
            <a href="{{ article.url }}" class="sf-news__card-link" aria-label="{{ article.title | escape }}">
              <div class="sf-news__card-image">
                {%- if article.image != blank -%}
                  <img src="{{ article.image | img_url: '600x400', crop: 'center' }}"
                       srcset="{{ article.image | img_url: '400x266', crop: 'center' }} 1x, {{ article.image | img_url: '800x534', crop: 'center' }} 2x"
                       alt="{{ article.image.alt | default: article.title | escape }}"
                       width="600" height="400"
                       loading="lazy">
                {%- else -%}
                  <div class="sf-news__card-no-img">
                    <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.2" aria-hidden="true"><rect x="3" y="3" width="18" height="18" rx="2"/><path d="M3 9h18M9 21V9"/></svg>
                  </div>
                {%- endif -%}
              </div>
              <div class="sf-news__card-body">
                <time class="sf-news__card-date" datetime="{{ article.published_at | date: '%Y-%m-%d' }}">
                  {{ article.published_at | date: '%d %b %Y' }}
                </time>
                <h3 class="sf-news__card-title">{{ article.title }}</h3>
                {%- if article.excerpt_or_content != blank -%}
                  <p class="sf-news__card-excerpt">{{ article.excerpt_or_content | strip_html | truncate: 90 }}</p>
                {%- endif -%}
              </div>
            </a>
          </article>
        {%- endfor -%}
      </div>
    {%- else -%}
      <div class="sf-news__empty">
        <p>{% if is_ar %}لا توجد مقالات حتى الآن.{% else %}No articles yet.{% endif %}</p>
      </div>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "SHOP FIVE — Recent News",
  "class": "shopify-section--sf-recent-news",
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": "Section title"
    },
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog"
    },
    {
      "type": "range",
      "id": "posts_count",
      "label": "Number of posts",
      "min": 2,
      "max": 4,
      "step": 1,
      "default": 4
    }
  ],
  "presets": [
    {
      "name": "SHOP FIVE — Recent News",
      "category": "Blog"
    }
  ]
}
{% endschema %}
